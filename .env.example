POSTGRES_USER=metafarm_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=metafarm_db
DATABASE_URL=postgresql://metafarm_user:change_me@localhost:5433/metafarm_db
DOCKER_DATABASE_URL=postgresql://metafarm_user:change_me@db:5432/metafarm_db
VITE_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ถ้าจะทดสอบจากมือถือในวง LAN ให้เปลี่ยนเป็น http://<LAN_IP>:8000 และเพิ่ม origin ของ frontend เช่น http://<LAN_IP>:5173
CORS_ORIGIN_REGEX=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_please
JWT_SECRET_KEY=change_me_super_secret_key_with_at_least_32_bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=14
REFRESH_COOKIE_NAME=metafarm_refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
WEATHER_CACHE_TTL_SECONDS=300
LOG_LEVEL=INFO
OPENWEATHER_API_KEY=your_openweather_api_key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
